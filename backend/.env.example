# =============================================================================
# RootAgent Backend Environment
# Copy to backend/.env and align with infra-hub credentials
# =============================================================================

# -----------------------------------------------------------------------------
# App / Deploy
# -----------------------------------------------------------------------------
API_PORT=8890
APP_PUBLIC_URL=https://rootagent.skt27182.com
APP_PUBLIC_HOST=rootagent.skt27182.com
SERVICE_PUBLIC_HOST=rootagent.skt27182.com
CORS_ORIGINS=http://localhost:5145,http://127.0.0.1:5145
DEBUG=true
LOG_LEVEL=INFO
LOG_PATH=./logs

# -----------------------------------------------------------------------------
# PostgreSQL (dedicated rootagent database)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=54321
POSTGRES_DB=rootagent
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
# Optional override:
# POSTGRES_URL=postgresql+asyncpg://admin:password@localhost:54321/rootagent

POSTGRES_CONTAINER_NAME=infra-postgres

# -----------------------------------------------------------------------------
# Redis (chat/session history only)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=63791
REDIS_PASSWORD=password
REDIS_SSL=false
SESSION_TTL_SECONDS=172800

REDIS_CONTAINER_NAME=infra-redis

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=rootagent
MINIO_SECURE=false
MINIO_CONTAINER_NAME=infra-minio

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# infra-hub main_db (read-only; admins in main_db.users get INFRA_ADMIN in RootAgent)
INFRA_HUB_POSTGRES_DB=main_db
# Optional override:
# INFRA_HUB_POSTGRES_URL=postgresql://admin:password@localhost:54321/main_db

# Swagger docs (HTTP Basic)
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=change-me

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
LLM_API_KEY=
LLM_MODEL=openrouter/amazon/nova-2-lite-v1:free
TAVILY_API_KEY=
